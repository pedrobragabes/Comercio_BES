# Comercio BES - variaveis de ambiente
# Copie este arquivo para .env na raiz do projeto.
# Em producao, configure estes valores no painel do host.

# Banco
# Use PostgreSQL. Recomendado: Supabase.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Opcional: apenas para rodar npm test com banco isolado.
TEST_DATABASE_URL=""

# Servidor
NODE_ENV="production"
PORT=3000

# Homologacao privada
# Defina SITE_PASSWORD em producao/homologacao para exigir usuario/senha no navegador.
SITE_USERNAME="comerciobes"
SITE_PASSWORD=""

# Auth
# Gere uma chave longa e aleatoria. Exemplo: openssl rand -base64 64
JWT_SECRET="trocar-por-uma-chave-secreta-longa-e-aleatoria"

# CORS
# Em producao, informe a URL publica do site.
# Pode receber mais de uma origem separada por virgula.
FRONTEND_URL="https://comerciobes.com.br"

# Upload de imagens opcional
# Se ausente, o sistema usa backend/uploads local. Para producao, prefira Cloudinary.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Cookie domain
# Deixe vazio para app tudo junto em comerciobes.com.br.
# Use .comerciobes.com.br somente se separar frontend e API em subdominios.
COOKIE_DOMAIN=""

# Pagamentos Mercado Pago - opcional
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
WEBHOOK_BASE_URL="https://comerciobes.com.br"
