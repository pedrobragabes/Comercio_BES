# Comercio BES - variaveis de ambiente
# Copie para .env no ambiente local. Em producao, configure no painel do host.

# Banco
# Use PostgreSQL. Recomendado: Supabase.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
TEST_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/comercio_bes_test"

# Servidor
NODE_ENV="development"
PORT=3000

# Auth
# Gere uma chave longa e aleatoria. Exemplo: openssl rand -base64 64
JWT_SECRET="trocar-por-uma-chave-secreta-longa-e-aleatoria"

# CORS
# Em producao, informe a URL publica do frontend.
# Pode receber mais de uma origem separada por virgula.
FRONTEND_URL="http://localhost:8080"

# Upload de imagens opcional
# Se ausente, o sistema usa backend/uploads local. Para producao, prefira Cloudinary.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Cookie Domain (cross-subdomain auth) ---
# Em produção com frontend em comerciobes.com.br e backend em api.comerciobes.com.br,
# defina COOKIE_DOMAIN=.comerciobes.com.br para que o csrf_token seja legível pelo JS
# do domínio principal. Deixe vazio em dev (cookies ficam limitados ao host que os setou).
COOKIE_DOMAIN=""

# --- Pagamentos (Mercado Pago) ---
# Sandbox: use credenciais de teste do Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
WEBHOOK_BASE_URL="http://localhost:3000"
