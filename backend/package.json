{
  "name": "comercio-bes-backend",
  "version": "1.0.0",
  "description": "API REST e Painel Admin do Comercio BES - Boa Esperanca do Sul",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "npx prisma generate",
    "predev": "node scripts/ensure-prisma-client.js",
    "dev": "nodemon src/server.js",
    "prestart": "node scripts/ensure-prisma-client.js",
    "build": "prisma generate",
    "start": "node src/server.js",
    "seed": "node src/seed.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:seed": "node src/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && node src/seed.js",
    "setup": "npm install && npx prisma generate && npx prisma db push && node src/seed.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --runInBand --watch"
  },
  "keywords": [
    "comercio",
    "boa-esperanca-do-sul",
    "marketplace",
    "api"
  ],
  "author": "Pedro",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "prisma": "^6.4.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "slugify": "^1.6.6",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
