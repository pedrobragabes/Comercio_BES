// ===========================================
// Prisma Schema - Comercio BES
// ===========================================
// Banco alvo atual: PostgreSQL.
// Em desenvolvimento e producao, configure DATABASE_URL no .env ou no host.

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Usuarios (comerciantes, clientes, admin) ---
// tipo: "cliente" | "comerciante" | "admin"
// Comerciantes preenchem: nomeFantasia, cpfCnpj, enderecoComercial, telefoneComercial
// Clientes preenchem: cpf, enderecos (via Endereco model)
model User {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  tipo      String   @default("cliente") // cliente | comerciante | admin
  telefone  String?
  avatar    String?  // URL da foto de perfil
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Campos exclusivos COMERCIANTE ---
  nomeFantasia      String?  // Nome fantasia do negocio
  cpfCnpj           String?  // CPF ou CNPJ do comerciante
  enderecoComercial String?  // Endereco comercial
  telefoneComercial String?  // Telefone comercial / WhatsApp do negocio

  // --- Campos exclusivos CLIENTE ---
  cpf String? // CPF do cliente (para pagamentos)

  // --- Auth: refresh token ---
  refreshTokenHash String? // Hash bcrypt do refresh token ativo (null = nenhum)

  // --- Relacoes ---
  comercios   Comercio[]
  avaliacoes  Avaliacao[]
  enderecos   Endereco[]
  pedidos     Pedido[]     @relation("ClientePedidos")
  auditLogs   AuditLog[]

  @@map("users")
}

// --- Enderecos de entrega (clientes podem ter varios) ---
model Endereco {
  id         Int      @id @default(autoincrement())
  userId     Int
  apelido    String   @default("Casa") // Casa, Trabalho, etc.
  rua        String
  numero     String
  complemento String?
  bairro     String
  cidade     String   @default("Boa Esperança do Sul")
  estado     String   @default("SP")
  cep        String
  principal  Boolean  @default(false) // Endereco padrao
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pedidos Pedido[]

  @@map("enderecos")
}

// --- Categorias ---
model Categoria {
  id    Int    @id @default(autoincrement())
  nome  String @unique
  slug  String @unique
  emoji String @default("")

  comercios Comercio[]

  @@map("categorias")
}

// --- Comercios (lojas) ---
model Comercio {
  id           Int      @id @default(autoincrement())
  slug         String   @unique
  nome         String
  categoriaId  Int
  tags         String   @default("[]") // JSON array como string
  emoji        String   @default("")
  descricao    String?
  aberto       Boolean  @default(true)
  endereco     String
  lat          Float
  lng          Float
  tel          String?
  whatsapp     String
  horario      String
  fotos        String   @default("[]") // JSON array como string
  visitas      Int      @default(0)
  recomendados Int      @default(0)
  ownerId      Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categoria    Categoria     @relation(fields: [categoriaId], references: [id])
  owner        User?         @relation(fields: [ownerId], references: [id])
  produtos     Produto[]
  promocao     Promocao?
  avaliacoes   Avaliacao[]
  estatisticas Estatistica[]
  pedidos      Pedido[]

  @@map("comercios")
}

// --- Produtos (catalogo) ---
model Produto {
  id          Int    @id @default(autoincrement())
  comercioId  Int
  nome        String
  descricao   String @default("")
  preco       Float
  imagem      String?
  disponivel  Boolean @default(true)
  ordem       Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)
  itensPedido ItemPedido[]

  @@map("produtos")
}

// --- Promocoes ---
model Promocao {
  id         Int     @id @default(autoincrement())
  comercioId Int     @unique
  ativo      Boolean @default(true)
  descricao  String
  preco      String
  original   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)

  @@map("promocoes")
}

// --- Avaliacoes ---
model Avaliacao {
  id         Int      @id @default(autoincrement())
  comercioId Int
  userId     Int?
  nota       Int      // 1 a 5
  comentario String?
  createdAt  DateTime @default(now())

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@map("avaliacoes")
}

// --- Estatisticas (visitas, cliques) ---
model Estatistica {
  id         Int      @id @default(autoincrement())
  comercioId Int
  tipo       String   // visita | whatsapp_click | telefone_click | compartilhamento
  ip         String?
  createdAt  DateTime @default(now())

  comercio Comercio @relation(fields: [comercioId], references: [id], onDelete: Cascade)

  @@map("estatisticas")
}

// ===========================================
// FASE 4 — Marketplace / Pedidos / Pagamentos
// ===========================================

// --- Pedidos ---
// status: pendente | confirmado | preparando | saiu_entrega | entregue | cancelado
// tipoEntrega: entrega | retirada
model Pedido {
  id            Int      @id @default(autoincrement())
  codigo        String   @unique // Codigo curto legivel: "BES-00001"
  clienteId     Int
  comercioId    Int
  enderecoId    Int?     // Null se retirada no local
  status        String   @default("pendente")
  tipoEntrega   String   @default("entrega") // entrega | retirada
  subtotal      Float    // Soma dos itens
  taxaEntrega   Float    @default(0)
  desconto      Float    @default(0)
  total         Float    // subtotal + taxaEntrega - desconto
  observacao    String?  // Observacoes do cliente
  motivoCancelamento String? // Se cancelado, motivo
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cliente   User       @relation("ClientePedidos", fields: [clienteId], references: [id])
  comercio  Comercio   @relation(fields: [comercioId], references: [id])
  endereco  Endereco?  @relation(fields: [enderecoId], references: [id])
  itens     ItemPedido[]
  pagamento Pagamento?

  @@map("pedidos")
}

// --- Itens do Pedido (snapshot do produto no momento da compra) ---
model ItemPedido {
  id         Int    @id @default(autoincrement())
  pedidoId   Int
  produtoId  Int?   // Referencia opcional (produto pode ser excluido depois)
  nome       String // Snapshot do nome do produto
  preco      Float  // Snapshot do preco no momento
  quantidade Int    @default(1)

  pedido  Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto? @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  @@map("itens_pedido")
}

// --- Pagamentos (Mercado Pago) ---
// metodo: pix | cartao_credito | cartao_debito | boleto | na_entrega
// status: pendente | aprovado | recusado | devolvido | em_analise
model Pagamento {
  id                Int      @id @default(autoincrement())
  pedidoId          Int      @unique
  mercadoPagoId     String?  // ID da transacao no Mercado Pago
  preferenceId      String?  // ID da preferencia de pagamento MP
  metodo            String?  // pix | cartao_credito | cartao_debito | boleto | na_entrega
  status            String   @default("pendente")
  valor             Float
  pixQrCode         String?  // QR code PIX (base64 ou copia-cola)
  pixQrCodeBase64   String?  // Imagem do QR code
  mercadoPagoStatus String?  // Status raw do MP
  detalhes          String?  // JSON com detalhes extras do MP
  paidAt            DateTime? // Quando foi pago
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("pagamentos")
}

// --- Audit Log (acoes criticas de admin) ---
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String   // ex: "user.delete", "store.moderate", "role.change"
  resource  String   // ex: "User:42", "Comercio:7"
  meta      String?  // JSON serializado
  ip        String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
